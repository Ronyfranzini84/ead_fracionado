<BoxPage>:
    FloatLayout:
        canvas:
            Color:
                rgb: utils.get_color_from_hex("#001824")
            Rectangle:
                size: self.size
                pos: self.pos
        Image:
            pos_hint: {"right":1 , "top":1}
            size_hint: 1, 0.3
            source: "icones/confere.png"