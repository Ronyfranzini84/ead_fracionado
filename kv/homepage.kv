#:import utils kivy.utils

<HomePage>:
    FloatLayout:
        canvas:
            Rectangle:
                size: self.size
                pos: self.pos
                source: "icones/bg1.png"
        Label:
            pos_hint: {"right": 0.85, "top": 0.95}
            size_hint: 0.7, 0.2
            text: "Home Page"
            id: homepage
            markup: True
         # lista de itens
        ScrollView:
            pos_hint: {"right": 1, "top": 0.75}
            size_hint: 1, 0.63
            GridLayout:
                cols: 1
                id: lista_itens
                size_hint_y: None
                spacing: 2, 2
                height: self.minimum_height
                row_default_height: "90dp"
                row_force_default: True
                Label:
                    text: "Nenhum apontamento carregado ainda. Use esta tela para acompanhar os itens validados do dia."
                    text_size: self.width - dp(24), None
                    halign: "left"
                    valign: "middle"
                    padding: "12dp", "12dp"
                    color: utils.get_color_from_hex("#D9F3FF")
        FloatLayout:
            pos_hint: {"right": 1, "top": 0.12}
            size_hint: 1, 0.12
            canvas:

            ImageButton:
                pos_hint: {"right": 0.2, "top": 0.9}
                size_hint: 0.2, 0.8
                source: "icones/voltar.png"
                on_release: app.mudar_tela("loginpage")
            ImageButton:
                pos_hint: {"right": 0.98, "top": 0.9}
                size_hint: 0.2, 0.8
                source: "icones/salesman.png"
                on_release: app.mudar_tela("boxpage")
            