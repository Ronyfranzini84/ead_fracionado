#:include kv/loginpage.kv
#:include kv/homepage.kv
#:include kv/criarlogin.kv
#:include kv/boxpage.kv
#:import utils kivy.utils

FloatLayout:
    canvas:
        Color:
            rgb: utils.get_color_from_hex("#001824")
        Rectangle:
            size: self.size
            pos: self.pos
    Image:
        pos_hint: {"right":1 , "top":1}
        size_hint: 1, 0.3
        source: "icones/confere.png"
    ScreenManager:
        pos_hint: {"right":1 , "top":0.7}
        size_hint: 1, 0.7
        id: screen_manager
        LoginPage:
            name: "loginpage"
            id: loginpage
        HomePage:
            name: "homepage"
            id: homepage
        CriarLoginPage:
            name: "criarconta"
            id: criarconta
        BoxPage:
            name: "boxpage"
            id: boxpage



 
